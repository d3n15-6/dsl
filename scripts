ventana: Formulario Visual Interactivo
dimensiones: 900x700
color RGB: 230,240,255

iniciar vbox: espaciado 20, padding 30x40, alineacion top-center, estilo fondo-claro
    label: texto "📝 Registro de Usuario", estilo titulo-seccion

    iniciar hbox: espaciado 15, alineacion center-left
        label: texto "Nombre:"
        textfield: id nombre, prefWidth 300
    finalizar hbox

    iniciar hbox: espaciado 15, alineacion center-left
        label: texto "Correo:"
        textfield: id correo, prefWidth 300
    finalizar hbox

    iniciar hbox: espaciado 15, alineacion center-left
        label: texto "Contraseña:"
        passwordfield: id pass, prefWidth 300
    finalizar hbox

    iniciar hbox: espaciado 20, alineacion center, padding 20x0, vgrow always
        boton: texto "Registrar", id btnAceptar, estilo primario
        boton: texto "Cancelar", id btnCancelar, estilo secundario
    finalizar hbox

finalizar vbox

al clic btnAceptar: mostrar mensaje "Usuario registrado con éxito"
al clic btnCancelar: cerrar ventana

