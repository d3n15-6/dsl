+    finalizar menu
+
+    iniciar menu: texto "JavaFX 2.0 Examples"
+      menuitem: texto "Text Example"
+      menuitem: texto "Objects Example"
+      menuitem: texto "Animation Example"
+    finalizar menu
+
+    iniciar menu: texto "Help"
+      menuitem: texto "Search", deshabilitado
+      menuitem: texto "Online Manual", visible falso
+      separador menuitem:
+      menuitem: texto "About", al_accion: handleAboutAction # onAction
+    finalizar menu
+
+  finalizar menubar
+finalizar vbox
+---------------- Ejemplo de MenuBar, Menu ---------------
