+    # Contenedor VBox anidado dentro del HBox
+    iniciar vbox: hgrow ALWAYS, max-alto INFINITO, max-ancho INFINITO, pref-alto 800, pref-ancho 200, alineacion CENTRO, estilo bg-1
+        # Botón dentro del VBox
+        boton: texto "VBox Button", id leftBtnV
